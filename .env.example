# EVE SSO application client ID (from https://developers.eveonline.com).
# Copy this file to `.env.local` and fill in your client ID.
#
# When registering the app:
#   - Authentication: "Authorization Code" (PKCE — no secret needed)
#   - Callback URL:   http://localhost:5173/auth/callback   (dev)
#                     https://<your-domain>/auth/callback    (prod)
#   - Scopes:         esi-location.read_location.v1
#                     esi-location.read_ship_type.v1
#                     esi-location.read_online.v1
#                     esi-ui.open_window.v1
#                     esi-ui.write_waypoint.v1
#                     esi-universe.read_structures.v1
VITE_EVE_CLIENT_ID=
